-- STATS TRACKING
-- ============================================================
local stats = {
    serversVisited = 0,
    petsFound = 0,
    startTime = os.time(),
    lastError = nil,
}

local function printStats()
    local uptime = os.time() - stats.startTime
    local hours = math.floor(uptime / 3600)
    local mins = math.floor((uptime % 3600) / 60)
    print("[GAG2] ✓ STATS: " .. stats.serversVisited .. " servers  •  " .. stats.petsFound .. " pets  •  " .. hours .. "h " .. mins .. "m uptime")
end

-- ============================================================
-- MAIN LOOP WITH AUTO-RESTART
-- ============================================================
local function waitForMap()
    print("[GAG2] Waiting for pets to load...")
    repeat
        task.wait(0.5)
        local map = workspace:FindFirstChild("Map")
        if map then
            local spawns = map:FindFirstChild("WildPetSpawns")
            if spawns and #spawns:GetChildren() >= 1 then
                print("[GAG2] " .. #spawns:GetChildren() .. " pets found!")
                return
            end
        end
    until false
end

local function mainLoop()
    print("[GAG2 Scanner] Started | Server: " .. game.JobId)
    print("[GAG2 Scanner] HTTP func: " .. tostring(getHttpFunc()))
    print("[GAG2 Scanner] Min empty slots: " .. MIN_EMPTY_SLOTS)
    waitForMap()

    while true do
        local serverId = game.JobId
        stats.serversVisited = stats.serversVisited + 1
        print("[GAG2] Scanning " .. serverId .. "... (Server #" .. stats.serversVisited .. ")")

        -- Keep scanning until we actually get pets
        local petList = {}
        while #petList == 0 do
            petList = scanAllPets()
            if #petList == 0 then
                print("[GAG2] Scan returned 0 pets, retrying in 1s...")
                task.wait(1)
            end
        end

        stats.petsFound = stats.petsFound + #petList
        print("[GAG2] Found " .. #petList .. " pets (total: " .. stats.petsFound .. ")")
        local playerCount = #Players:GetPlayers()
        local maxPlayers  = 8
        print("[GAG2] Server population: " .. playerCount .. "/" .. maxPlayers)
 
        -- Check if any pets are Mythic/Super/Secret OR Big/Huge/Rainbow variant
        local RARE_RARITIES = { Mythic = true, Super = true, Secret = true }
        local RARE_VARIANTS = { BIG = true, HUGE = true, RAINBOW = true }
        local hasRarePet = false
        for _, p in ipairs(petList) do
            if RARE_RARITIES[p.rarity] or RARE_VARIANTS[p.variant] then
                hasRarePet = true
                break
            end
        end

        -- Always send webhook, waitForMap guarantees pets exist
        print("[GAG2] Sending webhook...")
        local ok, err = pcall(sendSummaryWebhook, petList, serverId, playerCount, maxPlayers, hasRarePet)
        if not ok then
            warn("[GAG2] Webhook error: " .. tostring(err))
        end
        task.wait(1)
 
    -- Hop immediately after scan
    local attempts = 0
    local hopped = false
    repeat
        attempts = attempts + 1
        print("[GAG2] Hop attempt #" .. attempts .. "/4...")
        hopServer()
        -- Wait up to 5s for teleport to initiate
        local elapsed = 0
        repeat
            task.wait(0.5)
            elapsed = elapsed + 0.5
        until game.JobId ~= serverId or elapsed >= 5
        if game.JobId ~= serverId then
            print("[GAG2] ✓ Hopped to: " .. game.JobId)
            hopped = true
            break
        end
    until attempts >= 4
    if not hopped then
        print("[GAG2] Hard teleport fallback...")
        pcall(function()
            TeleportService:Teleport(PLACE_ID)
        end)
        task.wait(8)
    end
    waitForMap()
    end
end

-- Kick/disconnect safety net at the top level
local function safeRejoin()
    task.wait(3)
    print("[GAG2] Attempting rejoin after disconnect...")
    pcall(function()
        TeleportService:Teleport(PLACE_ID)
    end)
end

pcall(function()
    game:GetService("CoreGui").RobloxGui.ChildAdded:Connect(function(child)
        if child.Name == "DisconnectedOverlay" then
            print("[GAG2] Disconnect screen detected! Rejoining...")
            safeRejoin()
        end
    end)
end)

while true do
    local ok, err = pcall(mainLoop)
    if not ok then
        stats.lastError = tostring(err)
        print("[GAG2] ⚠️ ERROR: " .. stats.lastError)
        printStats()
        print("[GAG2] Restarting in 5s...")
        task.wait(5)
        print("[GAG2] Restarting...")
    end
end
