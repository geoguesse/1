-- PET DATA MODULE (has .Rarity for each pet species)
-- ============================================================
local PetData = nil
pcall(function()
    PetData = require(ReplicatedStorage:WaitForChild("SharedData"):WaitForChild("PetData"))
end)

local RARITY_EMOJI = {
    Common   = "⚪",
    Uncommon = "🟢",
    Rare     = "🔵",
    Epic     = "🟣",
    Legendary= "🟡",
    Mythic   = "🔴",
    Super    = "🌈",
    Secret   = "⬛",
}

local RARITY_ORDER = {
    Secret = 1, Super = 2, Mythic = 3, Legendary = 4,
    Epic = 5, Rare = 6, Uncommon = 7, Common = 8
}

local function getRarity(petName)
    if not PetData then return "Common" end
    local ok, data = pcall(function() return PetData[petName] end)
    if ok and type(data) == "table" and data.Rarity then
        return tostring(data.Rarity)
    end
    return "Common"
end

local function abbreviateNumber(n)
    if type(n) ~= "number" then return "?" end
    if n >= 1e12 then return string.format("%.1fT", n / 1e12) end
    if n >= 1e9  then return string.format("%.1fB", n / 1e9)  end
    if n >= 1e6  then return string.format("%.1fM", n / 1e6)  end
    if n >= 1e3  then return string.format("%.1fK", n / 1e3)  end
    return tostring(math.floor(n))
end

local PET_PRICES = {
    ["Frog"]             = 10000,
    ["Bunny"]            = 20000,
    ["Owl"]              = 25000,
    ["Deer"]             = 50000,
    ["Turtle"]           = 70000,
    ["Robin"]            = 75000,
    ["Bee"]              = 1000000,
    ["Monkey"]           = 3000000,
    ["Bear"]             = 5000000,
    ["Golden Dragonfly"] = 9000000,
    ["Unicorn"]          = 12000000,
    ["Raccoon"]          = 15000000,
    ["Black Dragon"]     = false,  -- Guild Rewards, no price
    ["Ice Serpent"]      = false,  -- Guild Rewards, no price
}

local function getPetPrice(petName)
    local staticPrice = PET_PRICES[petName]
    if staticPrice then
        return abbreviateNumber(staticPrice) .. " 🪙"
    end
    if staticPrice == false then
        return nil  -- Known no-price pet (Guild Rewards etc.)
    end
    -- Unknown pet, fall back to PetData module
    if not PetData then return nil end
    local ok, price = pcall(function() return PetData.GetBasePrice(petName) end)
    if ok and type(price) == "number" and price > 0 then
        return abbreviateNumber(price) .. " 🪙"
    end
    local data = PetData[petName]
    if type(data) == "table" and type(data.BasePrice) == "number" and data.BasePrice > 0 then
        return abbreviateNumber(data.BasePrice) .. " 🪙"
    end
    return nil
end

