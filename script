local function getHttpFunc()
    if typeof(syn) == "table" and typeof(syn.request) == "function" then return syn.request end
    if typeof(http) == "table" and typeof(http.request) == "function" then return http.request end
    if typeof(http_request) == "function" then return http_request end
    if typeof(request) == "function" then return request end
    if typeof(HttpRequest) == "function" then return HttpRequest end
    return nil
end

-- ============================================================
-- VARIANT DETECTION
-- ============================================================
local function getVariant(petModel)
    -- PetType attribute = "Rainbow" if rainbow
    local petType = tostring(petModel:GetAttribute("PetType") or "")
    if petType == "Rainbow" then return "RAINBOW" end

    -- PetSize attribute = "Big" or "Huge"
    local petSize = tostring(petModel:GetAttribute("PetSize") or "")
    if petSize == "Huge" then return "HUGE" end
    if petSize == "Big"  then return "BIG"  end

    return "Normal"
end

-- Strips UUIDs, "WildPet", size words, underscores — leaves just the species name
local UUID_PATTERN = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"
local function getPetName(petModel)
    -- Prefer a clean species attribute
    local attr = petModel:GetAttribute("PetSpecies")
        or petModel:GetAttribute("PetType")
        or petModel:GetAttribute("Species")
        or petModel:GetAttribute("Pet")
    if attr then
        local s = tostring(attr):gsub(UUID_PATTERN, ""):gsub("_", " "):match("^%s*(.-)%s*$")
        if s ~= "" then return s end
    end

    -- Fall back to model name, stripping noise
    local n = petModel.Name
    n = n:gsub(UUID_PATTERN, "")   -- remove UUIDs
    n = n:gsub("WildPet", "")
    n = n:gsub("Rainbow", ""):gsub("Huge", ""):gsub("Big", "")
    n = n:gsub("_", " "):gsub("%s+", " "):match("^%s*(.-)%s*$")
    return (n ~= "") and n or "Unknown"
end

-- ============================================================
-- VARIANT EMOJI + COLOR HELPERS
-- ============================================================
local function variantEmoji(v)
    if v == "RAINBOW" then return "🌈" end
    if v == "HUGE"    then return "🔶" end
    if v == "BIG"     then return "🔷" end
    return "▪️"
end

local function variantLabel(v)
    if v == "RAINBOW" then return "**🌈 RAINBOW**" end
    if v == "HUGE"    then return "**🔶 HUGE**"    end
    if v == "BIG"     then return "**🔷 BIG**"     end
    return "Normal"
end

local function bestColor(petList)
    local color = 0x888888
    for _, p in ipairs(petList) do
        if p.variant == "RAINBOW" then return 0xFF00FF end
        if p.variant == "HUGE"    then color = 0xFF8C00 end
        if p.variant == "BIG" and color ~= 0xFF8C00 then color = 0x3498DB end
    end
    return color
end

-- ============================================================
-- SCAN ALL PETS
-- ============================================================
local function scanAllPets()
    local mapFolder = workspace:FindFirstChild("Map")
    if not mapFolder then warn("[GAG2] workspace.Map not found!") return {} end

    local petList = {}

    local container = mapFolder:FindFirstChild("WildPetSpawns")
    if not container then
        warn("[GAG2] WildPetSpawns not found!")
        return {}
    end

    for _, petModel in ipairs(container:GetChildren()) do
        local name    = getPetName(petModel)
        local variant = getVariant(petModel)
        local rarity  = getRarity(name)
        local price   = getPetPrice(name)
        table.insert(petList, { name = name, variant = variant, rarity = rarity, price = price })
    end

    -- Sort: rarest first
    local order = { RAINBOW = 1, HUGE = 2, BIG = 3, Normal = 4 }
    table.sort(petList, function(a, b)
        return (order[a.variant] or 4) < (order[b.variant] or 4)
    end)

    print("[GAG2] Scanned " .. #petList .. " pets from WildPetSpawns")
    return petList
end
-- ============================================================
-- BUILD + SEND WEBHOOK (one message, all pets)
-- ============================================================
local function sendSummaryWebhook(petList, serverId, playerCount, maxPlayers, isRare)
    local httpFunc = getHttpFunc()
    if not httpFunc then warn("[GAG2] No HTTP function found!") return end


    -- Count variants
    local counts = { RAINBOW = 0, HUGE = 0, BIG = 0, Normal = 0 }
    for _, p in ipairs(petList) do counts[p.variant] = (counts[p.variant] or 0) + 1 end

    -- Header line
    local rareParts = {}
    if counts.RAINBOW > 0 then table.insert(rareParts, counts.RAINBOW .. "x 🌈 Rainbow") end
    if counts.HUGE    > 0 then table.insert(rareParts, counts.HUGE    .. "x 🔶 Huge")    end
    if counts.BIG     > 0 then table.insert(rareParts, counts.BIG     .. "x 🔷 Big")     end

    -- Also flag legendary+ rarities even if normal variant
    local HIGHLIGHT_RARITIES = { Legendary=true, Mythic=true, Super=true, Secret=true }
    local hasRarePet = false
    for _, p in ipairs(petList) do
        if HIGHLIGHT_RARITIES[p.rarity] then hasRarePet = true break end
    end

    local hasRare = #rareParts > 0 or hasRarePet
    local title   = hasRare
        and "🚨  RARE PETS  |  " .. (#rareParts > 0 and table.concat(rareParts, "  ·  ") or "Legendary+")
        or  "📋  " .. #petList .. " Pets This Server"

    -- Pet list lines
    local lines = {}
    for _, p in ipairs(petList) do
        local rarityEmoji = RARITY_EMOJI[p.rarity] or "⚪"
        local priceStr = p.price and ("  ·  " .. p.price) or ""
        local line = variantEmoji(p.variant) .. " " .. rarityEmoji .. "  **" .. p.name .. "**"
            .. "  |  " .. p.rarity
            .. "  ·  " .. variantLabel(p.variant)
            .. priceStr
        table.insert(lines, line)
    end
    local petBlock = #lines > 0 and table.concat(lines, "\n") or "_No pets found_"

    local embed = {{
        title       = title,
        color       = bestColor(petList),
        description = petBlock,
        fields = {
            {
                name   = "🖥️  Server ID",
                value  = "`" .. serverId .. "`",
                inline = true
            },
            {
                name   = "👥  Players",
                value  = playerCount and maxPlayers
                    and ("**" .. playerCount .. "** / " .. maxPlayers)
                    or  "Unknown",
                inline = true
            },
            {
                name   = "🔗  Join Server",
                value  = "https://www.roblox.com/games/start?placeId=" .. PLACE_ID .. "&gameInstanceId=" .. serverId,
                inline = false
            },

        },
        footer = { text = "GAG2 Scanner  •  " .. #petList .. " pets  •  " .. os.date("%I:%M:%S %p") }
    }}

    -- Ping role if any pet is Mythic or Super rarity
    local PING_RARITIES = { Mythic = true, Super = true }
    local PING_VARIANTS = { BIG = true, HUGE = true, RAINBOW = true }
    local shouldPing = false
    for _, p in ipairs(petList) do
        if PING_RARITIES[p.rarity] or PING_VARIANTS[p.variant] then
            shouldPing = true
            break
        end
    end

    local payload = HttpService:JSONEncode({
        content = shouldPing and ("<@&" .. PING_ROLE_ID .. "> 🚨 Rare pet spotted!") or nil,
        embeds  = embed
    })

    -- Try discord.com directly first, then proxies as fallback
    local urls = isRare and WEBHOOK_URLS_RARE or WEBHOOK_URLS
    local primaryUrl = isRare and ("https://discord.com" .. WEBHOOK_PATH_RARE) or ("https://discord.com" .. WEBHOOK_PATH)
    local orderedUrls = { primaryUrl }
    for _, url in ipairs(urls) do
        if not url:find("discord.com") then
            table.insert(orderedUrls, url)
        end
    end

    for _, url in ipairs(orderedUrls) do
        local res, ok, err
        ok, err = pcall(function()
            res = httpFunc({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = payload })
        end)
        local status = tostring(res and (res.StatusCode or res.status) or "err")
        print("[GAG2] " .. url:match("//([^/]+)") .. " → HTTP " .. status)
        if ok and (status == "200" or status == "204") then
            print("[GAG2] ✓ Webhook delivered!")
            return
        end
    end
    warn("[GAG2] All webhook attempts failed.")
end

-- ============================================================
-- SERVERHOPPER — fetches actual server list, picks different one
-- ============================================================
local function getServerList()
    local httpFunc = getHttpFunc()
    if not httpFunc then return nil end

    local url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100"
    local ok, res = pcall(httpFunc, { Url = url, Method = "GET" })
    if not ok or not res then return nil end

    local body = res.Body or res.body or ""
    local ok2, data = pcall(function() return HttpService:JSONDecode(body) end)
    if not ok2 or not data or not data.data then return nil end

    -- Return full objects: each has .id, .playing, .maxPlayers
    return data.data
end

-- Get info (playing, maxPlayers) for the current server specifically
-- Paginates through all servers to find the current JobId
local function getCurrentServerInfo()
    local httpFunc = getHttpFunc()
    if not httpFunc then return nil, nil end

    local currentId = game.JobId
    local cursor = ""

    for page = 1, 5 do -- check up to 5 pages (500 servers)
        local url = "https://games.roblox.com/v1/games/" .. PLACE_ID
            .. "/servers/Public?sortOrder=Asc&limit=100"
            .. (cursor ~= "" and ("&cursor=" .. cursor) or "")

        local ok, res = pcall(httpFunc, { Url = url, Method = "GET" })
        if not ok or not res then break end

        local body = res.Body or res.body or ""
        local ok2, data = pcall(function() return HttpService:JSONDecode(body) end)
        if not ok2 or not data or not data.data then break end

        for _, s in ipairs(data.data) do
            if s.id == currentId then
                return s.playing, s.maxPlayers
            end
        end

        -- Next page
        if data.nextPageCursor and data.nextPageCursor ~= "" then
            cursor = data.nextPageCursor
        else
            break
        end
    end

    return nil, nil
end

local function hopServer()
    local currentId = game.JobId
    local servers   = getServerList()

    if servers and #servers > 0 then
        local candidates = {}
        for _, s in ipairs(servers) do
            if s.id and s.id ~= currentId and s.playing and s.maxPlayers then
                local emptySlots = s.maxPlayers - s.playing
                if emptySlots >= MIN_EMPTY_SLOTS then
                    table.insert(candidates, { id = s.id, empty = emptySlots })
                end
            end
        end

        local target = nil
        if #candidates > 0 then
            table.sort(candidates, function(a, b) return a.empty > b.empty end)
            target = candidates[1].id
        else
            for _, s in ipairs(servers) do
                if s.id and s.id ~= currentId and s.playing and s.maxPlayers and (s.maxPlayers - s.playing) > 0 then
                    target = s.id
                    break
                end
            end
        end

        if target then
            local ok = pcall(function()
                TeleportService:TeleportToPlaceInstance(PLACE_ID, target, LocalPlayer)
            end)
            if not ok then
                pcall(function()
                    TeleportService:Teleport(PLACE_ID)
                end)
            end
            return
        end
    end

    -- Fallback
    pcall(function()
        TeleportService:Teleport(PLACE_ID)
    end)
end

